# =============================================================================
# AutoShip — Production Environment Variables
# Copy this file to .env and fill in the required values.
# =============================================================================

# --- Required ---

# Secret used by better-auth for signing sessions/tokens.
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# PostgreSQL password (used by both the database container and the API).
POSTGRES_PASSWORD=

# --- Optional (defaults shown) ---

# PostgreSQL
POSTGRES_USER=autoship
POSTGRES_DB=autoship
POSTGRES_PORT=5432

# Redis
REDIS_PASSWORD=autoship
REDIS_PORT=6379

# API
API_PORT=3001
WEB_URL=http://localhost:3000

# Web
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001

# Stripe (optional — billing features disabled without these)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
